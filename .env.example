# Infra only — everything else (UniFi controller, guest session defaults,
# portal/guest URLs, Pangolin, device caps, session security) is
# configured after first boot in the admin GUI (Settings), not here.
# See README "First-time setup".

# Database — Postgres runs in its own container (see docker-compose.yml).
# DATABASE_URL is built from POSTGRES_PASSWORD in docker-compose.yml.
# For local dev without Docker, point DATABASE_URL at your own Postgres instance:
DATABASE_URL="postgresql://portal:postgres@localhost:5432/portal"
POSTGRES_PASSWORD="generate-with-openssl-rand-hex-24"

# Admin panel — first-time-setup / recovery password (see README "Admin accounts & roles")
ADMIN_PASSWORD="change-this-password"
# Signs admin session cookies and encrypts secrets at rest. Losing this locks
# everyone out and makes stored secrets unreadable — back it up.
ADMIN_SECRET="generate-with-openssl-rand-hex-32"

# Optional: signs guest session/magic-link/email-verify tokens. Blank =
# derived from ADMIN_SECRET (fine for most deployments). Only set this if you
# want guest sessions fully isolated from the admin secret — changing it
# immediately invalidates all live guest sessions/magic links/email-verify
# links. Set this (and a separate admin host) when you split the guest and
# admin sides into two containers, so their session material shares nothing.
GUEST_SESSION_SECRET=""

# Process-role split (optional; blank = one container serves everything, the
# default). Run two containers off the same image to isolate the sides:
#   PORTAL_MODE="guest" — serves only the captive/guest side; /admin and
#     /api/admin return 404 here, and this process runs no background jobs.
#   PORTAL_MODE="admin" — serves only the admin side; guest pages 404 here.
# To enable with the bundled Traefik: set PORTAL_MODE="guest" here AND add
# "split" to the COMPOSE_PROFILES value setup.sh wrote, so it reads
# COMPOSE_PROFILES="traefik,split" (setup.sh manages that line; a split needs
# both profiles). Compose then also runs the portal-admin service (same image,
# PORTAL_MODE=admin pinned) and the portal routes the admin host at it
# automatically. Set BOTH — PORTAL_MODE without the profile, or the profile
# without PORTAL_MODE, is a half-configured state the app warns about at boot.
# The admin side needs its OWN hostname (Settings → URLs). Both containers read
# this .env (DATABASE_URL, ADMIN_SECRET, UniFi creds). See docs/OPERATIONS.md
# "Guest/admin split".
PORTAL_MODE=""

# Split behind an EXTERNAL Traefik: the URL your Traefik reaches the admin
# container at (compose service names don't resolve from outside, so the
# automatic http://portal-admin:3000 default is bundled-mode only). Blank =
# automatic; when set it always wins and the admin host routes there.
ADMIN_UPSTREAM_URL=""

# Background schedulers (alerts, metrics, reports, config history). Leave BLANK
# = on. In a split the admin container owns them automatically (it pins
# SCHEDULERS="" over this shared .env, and PORTAL_MODE="guest" already turns the
# guest container's off), so you do NOT set this for the split — a shared-.env
# "off" would silently disable them on BOTH containers. Only set "off" for a
# custom multi-process topology where each process gets its own environment.
SCHEDULERS=""

# Admin GUI URL (e.g. https://portal-adm.example.com). setup.sh asks for it
# when the bundled Traefik is chosen (no host port on the portal itself) and
# it is seeded into the portal's settings on first boot, so the admin GUI is
# routable before you can sign in to configure routing. GUI-managed afterwards
# (Settings -> URLs) — only read on a fresh database. Blank = browse by IP.
ADMIN_BASE_URL=""

# Second location for DB backups (mounted to /backups in the db container); default ./backups
BACKUP_PATH=./backups

# Optional: read-only GitHub token for non-interactive image pulls from
# GHCR (ghcr.io) on fresh hosts (setup.sh/deploy.sh).
# Blank = falls back to an interactive `docker login` prompt when a pull
# comes back unauthorized. Generate a GitHub personal access token
# with read:packages. Note: update.sh also reuses
# these vars as git credentials when github.com refuses anonymous access,
# which needs the repo scope too on a private repo.
GHCR_PULL_USER=""
GHCR_PULL_TOKEN=""

# Optional: read-only GitHub token for the update check
# (/api/version + the admin-sidebar "update available" badge). Setting it
# here enables the check with no admin-UI step; a token saved in Settings ->
# Monitoring takes precedence (stored AES-encrypted). Keep it repo-read-only.
UPDATE_CHECK_TOKEN=""

# Optional Traefik log dashboard (real-time access-log analytics — GeoIP,
# status codes, per-service metrics; https://github.com/hhftechnology/
# traefik-log-dashboard). Requires the bundled Traefik. Easiest:
# ./scripts/enable-logdash.sh. By hand: add "logdash" to COMPOSE_PROFILES
# (e.g. "traefik,logdash"), set both values below, `docker compose up -d`.
# The portal then writes a JSON access log via Traefik and routes
# LOGDASH_HOST at the dashboard — HTTPS-only, and every request is gated by
# the PORTAL'S OWN ADMIN SIGN-IN (Traefik forwardAuth back at the portal;
# first visit redirects through the admin host once). No extra credentials.
# See docs/OPERATIONS.md "Traefik log dashboard".
#   LOGDASH_TOKEN  shared agent↔UI token: openssl rand -hex 24
#   LOGDASH_HOST   dashboard hostname, e.g. logs.example.com (DNS →
#                  this host, same as the portal's other domains)
LOGDASH_TOKEN=""
LOGDASH_HOST=""
# Truncate Traefik's access log past this size (MB); default 256.
LOGDASH_LOG_MAX_MB=""
# Pin the dashboard images (default "latest"); see the project's releases.
LOGDASH_IMAGE_TAG=""
# Interactive update.sh runs offer to set the dashboard up while it is
# unconfigured ("./scripts/enable-logdash.sh" does the same by hand);
# answering "never" writes LOGDASH_PROMPT="off" here to silence the offer.
LOGDASH_PROMPT=""

# Which image tag this host runs: blank = "latest" (stable, main releases);
# "develop" = the integration branch's patch builds; "nightly" = the ungated
# fast-iteration branch (image-only CI — no tests, no scanners, no version
# tags; never run it anywhere you care about). Pair with the matching git
# branch checked out (update.sh pulls the branch it is on). A blank value is
# auto-filled by setup.sh/update.sh to match a develop/nightly checkout;
# explicit values are never touched.
IMAGE_TAG=""
